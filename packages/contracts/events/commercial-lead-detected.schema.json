{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "commercial-lead-detected.schema.json",
  "title": "commercial.lead.detected.v1",
  "type": "object",
  "required": ["event_id", "event_name", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_name": { "const": "commercial.lead.detected.v1" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": ["lead_id", "note_id", "category", "score", "suggested_product"],
      "properties": {
        "lead_id": { "type": "string", "minLength": 1 },
        "note_id": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "suggested_product": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
