{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "radar-brief-ready.schema.json",
  "title": "radar.brief.ready.v1",
  "type": "object",
  "required": ["event_id", "event_name", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_name": { "const": "radar.brief.ready.v1" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": ["idea_id", "brief_id", "confidence_score", "urgency", "summary"],
      "properties": {
        "idea_id": { "type": "string", "minLength": 1 },
        "brief_id": { "type": "string", "minLength": 1 },
        "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "urgency": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "summary": { "type": "string", "minLength": 1 },
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
