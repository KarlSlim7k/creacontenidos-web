{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metrics-snapshot-ready.schema.json",
  "title": "metrics.snapshot.ready.v1",
  "type": "object",
  "required": ["event_id", "event_name", "occurred_at", "producer", "payload"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_name": { "const": "metrics.snapshot.ready.v1" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": ["note_id", "window", "views", "engagement_rate", "cost_per_note"],
      "properties": {
        "note_id": { "type": "string", "minLength": 1 },
        "window": { "type": "string", "enum": ["15m", "1h", "24h", "7d"] },
        "views": { "type": "integer", "minimum": 0 },
        "engagement_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "cost_per_note": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
