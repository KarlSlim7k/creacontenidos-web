{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "apps/web",
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/nota/?$",
      "dest": "/pages/nota.html"
    },
    {
      "src": "^/seccion/?$",
      "dest": "/pages/seccion.html"
    },
    {
      "src": "^/comunidad/?$",
      "dest": "/pages/comunidad.html"
    },
    {
      "src": "^/comercial/?$",
      "dest": "/pages/comercial.html"
    },
    {
      "src": "^/colaboradores/?$",
      "dest": "/pages/colaboradores.html"
    },
    {
      "src": "^/tercer-tiempo/?$",
      "dest": "/pages/tercer-tiempo.html"
    },
    {
      "src": "/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      },
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, immutable"
        }
      ]
    }
  ]
}
